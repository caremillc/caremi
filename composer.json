{
    "name": "caremillc/caremi",
    "description": "A Project with Careminate modular enterprise PHP framework.",
    "type": "project",
    "license": "proprietary",
    "homepage": "https://caremi.com",
    "support": {
        "issues": "https://github.com/caremillc/caremi/issues",
        "source": "https://github.com/caremillc/caremi"
    },
    "authors": [
        {
            "name": "ikoncoders",
            "email": "caremillc@gmail.com",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "require": {
        "php": ">= 8.2",
        "vlucas/phpdotenv": "^5.6",
        "symfony/http-foundation": "^7.2",
        "caremillc/framework": "dev-main",
        "doctrine/inflector": "^2.1"
    },
    "require-dev": {
        "symfony/var-dumper": "6.3.x-dev",
        "phpunit/phpunit": "^11.0",
        "pestphp/pest": "^3.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "framework",
            "options": {
                "symlink": true
            }
        }
    ],
    "prefer-stable": true,
    "minimum-stability": "stable",
    "scripts": {
        "test": "phpunit",
        "serve": "php -S localhost:8000 -t public"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}