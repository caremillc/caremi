{
    "name": "caremillc/caremi",
    "description": "A Project with Careminate modular enterprise PHP framework.",
    "type": "project",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Factories\\": "database/factories/",
            "Modules\\": "modules/"
        }
    },
	"autoload-dev": {
        "psr-4": {
            "Careminate\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2",
        "caremillc/framework": "dev-main"
    },
    "require-dev": {
        "symfony/var-dumper": "6.3.x-dev",
        "phpunit/phpunit": "^11.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "framework",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
         
        ],
        "serve": "php -S localhost:8000 -t public"
    }
}