{
    "name": "caremillc/caremi",
    "description": "The Skeleton Application for the Caremi Framework.",
    "type": "project",
    "license": "MIT",
    "homepage": "https://caremi.com",
    "support": {
        "issues": "https://github.com/caremillc/caremi/issues",
        "source": "https://github.com/caremillc/caremi"
    },
    "authors": [
        {
            "name": "ikoncoders",
            "email": "caremillc@gmail.com",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "require": {
        "php": ">= 8.1",
        "caremillc/framework": "dev-main",
        "doctrine/inflector": "^2.1"
    },
    "require-dev": {
        "symfony/var-dumper": "6.3.x-dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "framework",
            "options": {
                "symlink": true
            }
        }
    ],
    "prefer-stable": true,
    "scripts": {
        "post-create-project-cmd": [
            "@php bin/setup-env.php"
        ],
        "post-install-cmd": [
            "@php bin/setup-env.php"
        ]
    }
}
