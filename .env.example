APP_NAME=Caremi
APP_ENV=dev
APP_URL=http://localhost
ASSET_URL=
APP_KEY=
APP_DEBUG=true
APP_VERSION=1.0.0

DB_DRIVER=mysql # sqlite/mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=forge
DB_USER=root
DB_PASSWORD=

APP_MAINTENANCE_DRIVER=file #file/cache
APP_MAINTENANCE_STORE=database #file/database

MYSQL_ATTR_SSL_CA=

EMAIL_SERVICE_API_KEY=
EMAIL_SERVICE_ENDPOINT=

SESSION_DRIVER=file #file/database
SESSION_PREFIX=caremi
SESSION_SAVE_PATH=storage/sessions
SESSION_EXPIRATION_TIMEOUT=7200
