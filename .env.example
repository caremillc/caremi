# ============================================
# APPLICATION
# ============================================
APP_ENV=local
APP_DEBUG=true
APP_NAME=Careminate
APP_VERSION=1.0.0
ASSET_URL=
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC


# ============================================
# SECURITY
# ============================================
APP_KEY=base64:YourBase64EncodedKeyHere==
CSRF_TOKEN_EXPIRY=3600

# ============================================
# DATABASE
# ============================================
# Choose one: sqlite, mysql, pgsql
DB_CONNECTION=mysql
# SQLite (for SQLite only)
DB_SQLITE=storage/database/database.sqlite
# MySQL/PostgreSQL (for mysql/pgsql only)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dev_caremi
DB_USERNAME=root
DB_PASSWORD=
# Optional: Database URL (overrides above)
# DATABASE_URL=mysql://user:password@localhost:3306/dbname

# ============================================
# SESSION & CACHE
# ============================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=storage/sessions

CACHE_DRIVER=file
CACHE_PATH=storage/cache


# ============================================
# LOGGING
# ============================================
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ============================================
# FILE UPLOADS
# ============================================
UPLOAD_MAX_SIZE=10485760  # 10MB
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,txt

# ============================================
# HTTP / REDIRECTS
# ============================================
REDIRECT_PRESERVE_RELATIVE=true