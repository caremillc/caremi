APP_ENV=local
APP_DEBUG=true
APP_NAME=Careminate
APP_VERSION=1.0.0
ASSET_URL=
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

# Security
APP_KEY=base64:YourBase64EncodedKeyHere==
CSRF_TOKEN_EXPIRY=3600

# Databases
DB_CONNECTION=sqlite  # Use sqlite, mysql, or pgsql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dev_caremi
DB_SQLITE=storage/database.sqlite
DB_USERNAME=root
DB_PASSWORD=

MYSQL_ATTR_SSL_CA=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/tmp

CACHE_DRIVER=file
CACHE_PATH=/tmp/caremi-cache

LOG_CHANNEL=stack
LOG_LEVEL=debug

# File upload limits
UPLOAD_MAX_SIZE=10485760  # 10MB
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,txt

#http 
REDIRECT_PRESERVE_RELATIVE=true 