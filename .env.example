#App
APP_NAME="Careminate Framework"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/caremi/public

# cache
CACHE_ROUTES=false
CACHE_CONFIG=false

# log
LOG_ENABLED=true
LOG_CHANNEL=file
LOG_FILE=storage/logs/app.log  

# Database Perematers
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=caremi
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=mail.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls

# Timezone
APP_TIMEZONE=Asia/Dubai
